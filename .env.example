# SERVICE wallet — used only to construct the keyless engine (reads, graph
# build, IPFS pinning). It does NOT sign users' on-chain settlements; each user
# signs those with their own Privy wallet in the browser. Needs no funds.
ETH_PRIVATE_KEY=0x...

# Pinata (IPFS pinning) credentials — where commit/vertex blocks are stored.
PINATA_JWT=...
PINATA_GATEWAY=example.mypinata.cloud

# Privy app id (public — also shipped to the browser). The server uses it to
# verify login tokens via Privy's JWKS. https://dashboard.privy.io
VITE_PRIVY_APP_ID=...

# Optional: port for the local API server (default 8787).
# PORT=8787
