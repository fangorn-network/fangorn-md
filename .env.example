# Wallet that signs pushes (must hold a little Arbitrum Sepolia ETH for gas).
ETH_PRIVATE_KEY=0x...

# Pinata (IPFS pinning) credentials — where commit/vertex blocks are stored.
PINATA_JWT=...
PINATA_GATEWAY=example.mypinata.cloud

# Optional: port for the local API server (default 8787).
# PORT=8787
