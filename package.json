{
  "name": "fangornmd",
  "version": "1.0.0",
  "description": "A personal, self-hosted HackMD-style wiki published to the Fangorn network",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "node --env-file=.env server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "graph": "node server/graph.js docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@fangorn-network/sdk": "2026.7.1-4.0",
    "@privy-io/react-auth": "^3.35.1",
    "@slate-yjs/core": "^1.0.2",
    "@y/websocket-server": "^0.1.5",
    "dompurify": "^3.4.12",
    "jose": "^6.2.3",
    "marked": "^18.0.6",
    "multiformats": "^14.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "slate": "^0.126.0",
    "slate-history": "^0.113.1",
    "slate-react": "^0.126.0",
    "viem": "^2.55.1",
    "ws": "^8.21.1",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "vite": "^8.1.4"
  }
}
